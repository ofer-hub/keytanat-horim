rules_version = '2';

// ─────────────────────────────────────────────────────────────────
// קייטנת הורים אריאל — Firestore Security Rules
//
// activities:  ציבורי לקריאה בלבד (אין מידע רגיש).
// שאר הcollections: דורשים משתמש רשום עם פרופיל תקין.
// admin: גישה מלאה לכל הcollections.
// ─────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    // exists() is cheaper than get() and sufficient for profile check
    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(myUid()));
    }

    function myUser() {
      return get(/databases/$(database)/documents/users/$(myUid())).data;
    }

    function isAdmin() {
      return hasUserProfile() && myUser().role == 'admin';
    }

    function isRegisteredParent() {
      return hasUserProfile() && myUser().role == 'parent';
    }

    function isRegisteredChild() {
      return hasUserProfile() && myUser().role == 'child';
    }

    function isRegisteredUser() {
      return isRegisteredParent() || isRegisteredChild() || isAdmin();
    }

    // ── users/{uid} ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        myUid() == uid ||
        isRegisteredParent() ||
        isAdmin()
      );
      allow update: if isAdmin()
        || (isSignedIn() && myUid() == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.familyId == resource.data.familyId);
      allow delete: if isAdmin();
    }

    // ── phoneIndex/{phone} ───────────────────────────────────────
    match /phoneIndex/{phone} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.uid == myUid() ||
        isRegisteredParent() ||
        isAdmin()
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── activities/{activityId} ──────────────────────────────────
    match /activities/{activityId} {
      allow read: if true;

      allow create: if isRegisteredParent() || isAdmin();

      allow update: if isAdmin()
        || (isRegisteredParent() && myUid() == resource.data.createdByParentId)
        || (isRegisteredChild()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['childCount'])
            && request.resource.data.childCount >= 0
            && (request.resource.data.childCount == resource.data.get('childCount', 0) + 1
                || request.resource.data.childCount == resource.data.get('childCount', 0) - 1))
        || (isRegisteredParent()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seatCount'])
            && request.resource.data.seatCount >= 0);

      allow delete: if isAdmin()
        || (isRegisteredParent() && myUid() == resource.data.createdByParentId);
    }

    // ── activityEscorts/{escortId} ───────────────────────────────
    match /activityEscorts/{escortId} {
      allow read: if isRegisteredUser();
      allow create: if isRegisteredParent() || isAdmin();
      allow update: if isAdmin()
        || (isRegisteredParent() && myUid() == resource.data.parentId);
      allow delete: if isAdmin()
        || (isRegisteredParent()
            && myUid() == resource.data.parentId
            && resource.data.isCreator == false);
    }

    // ── activityRegistrations/{regId} ────────────────────────────
    match /activityRegistrations/{regId} {
      allow read: if isRegisteredUser();
      allow create: if isAdmin()
        || (isRegisteredChild() && request.resource.data.childId == myUid());
      allow delete: if isAdmin()
        || (isRegisteredChild() && myUid() == resource.data.childId);
    }
  }
}
