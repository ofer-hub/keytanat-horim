rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(myUid()));
    }

    function myUser() {
      return get(/databases/$(database)/documents/users/$(myUid())).data;
    }

    function isAdmin() {
      return hasUserProfile() && myUser().role == 'admin';
    }

    function isRegisteredParent() {
      return hasUserProfile() && myUser().role == 'parent';
    }

    function isRegisteredChild() {
      return hasUserProfile() && myUser().role == 'child';
    }

    function isRegisteredUser() {
      return isRegisteredParent() || isRegisteredChild() || isAdmin();
    }

    // ── users/{uid} ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        myUid() == uid ||
        isRegisteredParent() ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (myUid() == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.familyId == resource.data.familyId)
      );
      // Any signed-in user can delete — admin panel enforces app-level auth
      allow delete: if isSignedIn();
    }

    // ── phoneIndex/{phone} ───────────────────────────────────────
    match /phoneIndex/{phone} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.uid == myUid() ||
        isRegisteredParent() ||
        isAdmin()
      );
      allow update: if isSignedIn() && isAdmin();
      // Any signed-in user can delete
      allow delete: if isSignedIn();
    }

    // ── activities/{activityId} ──────────────────────────────────
    match /activities/{activityId} {
      allow read: if true;
      // isSignedIn() covers admin whose Firestore doc may not exist yet
      allow create: if isSignedIn();
      // Any registered parent can edit any activity field (including admin-created)
      allow update: if isAdmin()
        || isRegisteredParent()
        || (isRegisteredChild()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['childCount'])
            && request.resource.data.childCount >= 0
            && (request.resource.data.childCount == resource.data.get('childCount', 0) + 1
                || request.resource.data.childCount == resource.data.get('childCount', 0) - 1));
      // Any signed-in user (parent or admin) can delete any activity
      allow delete: if isSignedIn();
    }

    // ── activityEscorts/{escortId} ───────────────────────────────
    match /activityEscorts/{escortId} {
      allow read: if isRegisteredUser();
      allow create: if isRegisteredParent() || isAdmin();
      allow update: if isAdmin()
        || (isRegisteredParent() && myUid() == resource.data.parentId);
      // isSignedIn() covers admin cascade-delete of escorts when deleting activity
      allow delete: if isSignedIn() && (
        isAdmin() ||
        myUid() == resource.data.parentId ||
        (isRegisteredParent()
            && myUid() == resource.data.parentId
            && resource.data.isCreator == false)
      );
    }

    // ── activityRegistrations/{regId} ────────────────────────────
    match /activityRegistrations/{regId} {
      allow read: if isRegisteredUser();
      // Parents can register their children; children register themselves
      allow create: if isAdmin()
        || isRegisteredParent()
        || (isRegisteredChild() && request.resource.data.childId == myUid());
      // Parents can unregister their children; children unregister themselves
      allow delete: if isSignedIn() && (
        isAdmin() ||
        isRegisteredParent() ||
        myUid() == resource.data.childId
      );
    }
  }
}
